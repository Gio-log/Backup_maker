<UserControl x:Class="Backup_Maker.Views.UserControls.TitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Backup_Maker.Views.UserControls"
             mc:Ignorable="d" 
             Background="Transparent"
             Height="40" d:DesignWidth="800"
             MouseLeftButtonDown="UserControl_MouseLeftButtonDown">
    <Grid Background="#282828" Margin="0,0,0,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="18" Foreground="White" VerticalAlignment="Center" FontWeight="Medium" Padding="10,0,0,0" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" >
            <Button Content="—" Click="Minimize_Click" Width="25" Background="Transparent" Foreground="White" />
            <Button Content="□" Click="Maximize_Click" Width="25" Background="Transparent" Foreground="White" />
            <Button Content="✕" Click="Close_Click" Width="25" Background="Transparent" Foreground="White" />
        </StackPanel>
    </Grid>
</UserControl>
