<UserControl x:Class="Backup_Maker.Views.UserControls.BackupControls"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Backup_Maker.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="80" />
            <ColumnDefinition Width="*" MinWidth="150" />
            <ColumnDefinition Width="*" MinWidth="80" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Button Content="Change files source" x:Name="filesLocationButton" 
        VerticalAlignment="Center" HorizontalAlignment="Center" 
        Grid.Row="0" Grid.Column="1" MinWidth="150"
        Command="{Binding filesLocationChangeCommand}"/>
        <Button Content="Restore" x:Name="restoreButton" 
        VerticalAlignment="Center" HorizontalAlignment="Center" 
        Grid.Row="0" Grid.Column="2" MinWidth="80"
        Command="{Binding restoreCommand}"/>
        <Button Content="Delete selected files" x:Name="deleteButton" 
        VerticalAlignment="Center" HorizontalAlignment="Center" 
        Grid.Row="1" Grid.Column="1" MinWidth="150"
        Command="{Binding deleteCommand}"/>
        <Button Content="Backup" x:Name="backupButton" 
        VerticalAlignment="Center" HorizontalAlignment="Center" 
        Grid.Row="1" Grid.Column="2" MinWidth="80"
        Command="{Binding backupCommand}"/>
        <Button Content="Unselect" x:Name="unselectButton" 
        VerticalAlignment="Center" HorizontalAlignment="Center" 
        Grid.Row="0" Grid.Column="0" MinWidth="80"
        Command="{Binding unselectCommand}"/>
        <CheckBox Content="Overwrite"
        Grid.Row="1" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
    </Grid>
</UserControl>
