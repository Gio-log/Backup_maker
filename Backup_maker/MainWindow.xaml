<Window x:Class="Backup_Maker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Backup_Maker"
        xmlns:userControls="clr-namespace:Backup_Maker.Views.UserControls"
        mc:Ignorable="d"
        Title="Backup Maker" Height="500" Width="950" FontSize="15" MinWidth="670" MinHeight="200">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="1*" MinWidth="320" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="1*" MinWidth="320" />
            <ColumnDefinition Width="10" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
        </Grid.RowDefinitions>
        <!--<userControls:MenuBar />-->
        <TextBlock Text="{Binding FilesLocation}" Name="filesLocationTextBlock"
                   Grid.Row="1" Grid.Column="1" />
        <Label Content="Backups" Name="bLabel" 
                   HorizontalAlignment="Center"
                   Grid.Row="3" Grid.Column="4"/>
        <userControls:BackupControls 
            Grid.Row="1" Grid.Column="3"/>
        <userControls:SearchBar SearchFile="{Binding SearchFile, Mode=TwoWay}"
            Grid.Row="2" Grid.Column="1"/>
        <userControls:SearchBar SearchFile="{Binding SearchBackup, Mode=TwoWay}"
    Grid.Row="2" Grid.Column="3"/>
        <userControls:FileList 
            Grid.Row="3" Grid.Column="1"/>
        <userControls:BackupList 
            Grid.Row="3" Grid.Column="3"/>
    </Grid>
</Window>
